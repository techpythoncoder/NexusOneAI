# Auth Service environment — copy to .env and fill in secrets
# Each service is self-contained — no global .env, only this file matters.

SERVICE_NAME=auth-service
DEBUG=false
PORT=8001

# This service's Postgres
# Standalone: postgresql+asyncpg://nexus:nexus_secret_2024@localhost:5440/nexus_auth
# Full-stack:  postgresql+asyncpg://nexus:nexus_secret_2024@postgres:5432/nexus_auth
DATABASE_URL=postgresql+asyncpg://nexus:nexus_secret_2024@auth-postgres:5432/nexus_auth
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (STAFIO's existing Redis)
REDIS_URL=redis://redis:6379/0
REDIS_TOKEN_DB=1

# JWT
JWT_SECRET_KEY=nexusone-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=Ov23lidXVNcQBqOwJKlg
GITHUB_CLIENT_SECRET=38fc53bda85bd3721f611b544467bfbc29209cf0
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback

# Kafka (STAFIO's existing Kafka)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_USER_EVENTS=nexus.user.events

# Email — MailHog for local dev
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@nexusone.ai

FRONTEND_URL=http://localhost:3002

# Backblaze B2 — S3-compatible object storage for avatars / uploads
B2_KEY_ID=0051da38167654f0000000002
B2_APPLICATION_KEY=K005vts+yVKCOlQjlKZQAC+Ws50aF9E
B2_ENDPOINT=s3.us-east-005.backblazeb2.com
B2_BUCKET=docmind-uploads

# OpenTelemetry → Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_ENABLED=true
